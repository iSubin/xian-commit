#!/bin/sh
# hooks/pre-commit
# 校验 staged 文件路径,拒绝黑名单文件
# 失败时 exit 1,git commit 中止

# 禁用 glob 展开,防止 $BLACKLIST_PATTERNS 在 for 循环中被当前目录文件替换
set -f

POLICY_FILE="${XIAN_COMMIT_CONFIG:-.xian-commit/config}"

policy_value() {
    key="$1"
    [ -f "$POLICY_FILE" ] || return 0
    awk -F= -v key="$key" '
        $0 ~ /^[[:space:]]*#/ { next }
        $0 !~ /=/ { next }
        {
            k=$1
            sub(/^[[:space:]]+/, "", k)
            sub(/[[:space:]]+$/, "", k)
            if (k == key) {
                sub(/^[^=]*=/, "")
                sub(/^[[:space:]]+/, "")
                sub(/[[:space:]]+$/, "")
                print
                exit
            }
        }
    ' "$POLICY_FILE"
}

# allowlist 先于 denylist 生效,用于协议证据或项目明确允许的审计产物。
ALLOW_PATTERNS="
docs/xian-harness/changes/*/.change-transition.log
docs/xian-harness/changes/*/verify/evidence/logs/*.log
docs/xian-harness/evidence/*/*.log
cases/*/docs/xian-harness/changes/*/.change-transition.log
cases/*/docs/xian-harness/changes/*/verify/evidence/logs/*.log
cases/*/docs/xian-harness/evidence/*/*.log
"

configured_allow=$(policy_value "path.allow")
if [ -n "$configured_allow" ]; then
    ALLOW_PATTERNS="$ALLOW_PATTERNS
$configured_allow"
fi

# 黑名单模式(glob),任一匹配则拦截
# 注意:不要太宽,避免误杀合法文件(如 debug.py)
BLACKLIST_PATTERNS="
.xian-relay*
*/.xian-relay*
*.tmp
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.env
*.env.local
*.env.*.local
id_rsa
id_dsa
id_ed25519
id_ecdsa
*_tmp.py
*_tmp.*
*.bak
"

configured_deny=$(policy_value "path.deny")
if [ -n "$configured_deny" ]; then
    BLACKLIST_PATTERNS="$BLACKLIST_PATTERNS
$configured_deny"
fi

# 对传入的完整路径做匹配。该内部模式由 xargs -0 分批调用，
# 因此空格、中文和换行都不会在进入 shell 前被拆分或转义。
check_paths() {
    found=0
    for file do
        allowed=0
        for pattern in $ALLOW_PATTERNS; do
            [ -z "$pattern" ] && continue
            case "$file" in
                $pattern)
                    allowed=1
                    break
                    ;;
            esac
        done
        if [ "$allowed" -eq 1 ]; then
            continue
        fi

        basename=${file##*/}
        for pattern in $BLACKLIST_PATTERNS; do
            [ -z "$pattern" ] && continue
            matched=0
            case "$file" in
                $pattern) matched=1 ;;
            esac
            if [ "$matched" -eq 0 ]; then
                case "$basename" in
                    $pattern) matched=1 ;;
                esac
            fi
            if [ "$matched" -eq 1 ]; then
                printf '  - %s   (匹配黑名单 %s)\n' "$file" "$pattern"
                found=1
                break
            fi
        done
    done
    [ "$found" -eq 0 ]
}

if [ "${1:-}" = "--check-paths" ]; then
    shift
    check_paths "$@"
    exit $?
fi

# -z 让 Git 以 NUL 分隔原始路径，xargs -0 再把每个路径完整传入内部匹配模式。
staged_list=$(mktemp 2>/dev/null || mktemp -t xian-commit-staged)
trap 'rm -f "$staged_list"' 0 1 2 3 15
if ! git -c core.quotepath=false diff --cached --name-only -z > "$staged_list"; then
    echo "xian-commit pre-commit: 无法读取 staged 文件。" >&2
    exit 1
fi

if [ ! -s "$staged_list" ]; then
    exit 0
fi

violations=$(xargs -0 sh "$0" --check-paths < "$staged_list")
check_status=$?

if [ "$check_status" -ne 0 ] && [ -z "$violations" ]; then
    echo "xian-commit pre-commit: 敏感路径检查执行失败。" >&2
    exit 1
fi

if [ -n "$violations" ]; then
    cat >&2 <<EOF
xian-commit pre-commit: 拒绝提交以下文件,请先从 staged 移除:
$violations

修复:
  git reset HEAD <files>
EOF
    exit 1
fi

exit 0
