{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xian.local/schemas/agent-pair-providers.schema.json",
  "title": "Xian Harness Agent Pair Providers",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "providers"],
  "properties": {
    "version": {
      "const": 1
    },
    "providers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["adapter", "profile", "baseUrl", "apiKey", "model"],
        "properties": {
          "adapter": {
            "const": "claude-code"
          },
          "profile": {
            "const": "glm-backed"
          },
          "baseUrl": {
            "type": "string",
            "format": "uri"
          },
          "apiKey": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
